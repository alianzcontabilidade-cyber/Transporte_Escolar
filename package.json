{
  "name": "netescol",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=packages/api && npm run build --workspace=apps/web",
    "start": "npm run start --workspace=packages/api",
    "db:push": "npm run db:push --workspace=packages/api",
    "db:studio": "npm run db:studio --workspace=packages/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
